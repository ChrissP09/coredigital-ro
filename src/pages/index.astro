---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/ui/LucideIcon.astro';
import ProcessSteps from '../components/ui/ProcessSteps.astro';
---

<BaseLayout
  title="CoreDigital - Prezență online completă pentru business-uri locale"
  description="Tot ce are nevoie un business local online, într-un singur abonament lunar. Website modern, colectare review-uri și AI chatbot pentru afacerea ta."
>

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="relative overflow-hidden" style="background: hsl(var(--color-bg)); padding-top: 7rem; padding-bottom: 5rem;">

  <!-- Dot grid with radial mask — visible in the lit zone, fades at edges -->
  <div class="pointer-events-none absolute inset-0" style="background-image: radial-gradient(circle, hsl(var(--color-border) / 0.9) 1px, transparent 1px); background-size: 28px 28px; -webkit-mask-image: radial-gradient(ellipse 75% 80% at 50% 30%, black 20%, transparent 75%); mask-image: radial-gradient(ellipse 75% 80% at 50% 30%, black 20%, transparent 75%);"></div>

  <!-- Blob 1: lime — top center, main light source -->
  <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[860px] h-[480px]" style="background: radial-gradient(ellipse 55% 55% at 50% 0%, hsl(var(--color-lime) / 0.18) 0%, transparent 70%);"></div>

  <!-- Blob 2: lime — mid left, secondary depth -->
  <div class="pointer-events-none absolute top-1/3 -left-32 w-[500px] h-[400px]" style="background: radial-gradient(ellipse at 30% 50%, hsl(var(--color-lime) / 0.07) 0%, transparent 65%);"></div>

  <!-- Blob 3: sky — bottom right, cool contrast -->
  <div class="pointer-events-none absolute bottom-0 right-0 w-[400px] h-[300px]" style="background: radial-gradient(ellipse at 80% 100%, hsl(var(--color-sky) / 0.06) 0%, transparent 65%);"></div>

  <!-- Vignette corners -->
  <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 130% 110% at 50% 50%, transparent 40%, hsl(var(--color-bg) / 0.85) 100%);"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to top, hsl(var(--color-bg)), transparent);"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 mb-8 text-[0.7rem] font-mono tracking-wider uppercase" style="background: hsl(var(--color-surface) / 0.8); border: 1px solid hsl(var(--color-border)); color: hsl(var(--color-muted)); backdrop-filter: blur(8px);">
          <span class="w-1.5 h-1.5 rounded-full" style="background: var(--brand-color);"></span>
          Prezență digitală completă
        </div>

        <h1 class="mb-7" style="font-size: clamp(2.6rem, 5.5vw, 4rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1.04;">
          Prezență online<br/>completă prin<br/>
          <span style="color: var(--brand-color); text-shadow: 0 0 60px hsl(var(--color-lime) / 0.4);">abonament.</span>
        </h1>

        <p class="mb-10 max-w-[420px]" style="color: hsl(var(--color-muted)); font-size: 1.05rem; line-height: 1.7;">
          Website modern, colectare review-uri automate și AI chatbot pentru business-ul tău local — totul într-un singur abonament lunar predictibil.
        </p>

        <!-- Feature pills -->
        <div class="flex flex-wrap gap-3 mb-10">
          {[
            {icon: 'Zap',         label: 'Setup rapid'},
            {icon: 'CreditCard',  label: 'Abonament lunar'},
            {icon: 'ShieldCheck', label: 'Cost predictibil'},
          ].map(f => (
            <span class="inline-flex items-center gap-2 text-sm px-3 py-1.5 rounded-full border" style="background: hsl(var(--color-surface) / 0.6); border-color: hsl(var(--color-border)); color: hsl(var(--color-muted)); backdrop-filter: blur(8px);">
              <LucideIcon name={f.icon} size={13} style="color: var(--brand-color);" />
              {f.label}
            </span>
          ))}
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="u-brand-cta u-btn-lg u-btn-split" href="/preturi">
            Vezi pachetele
            <span class="btn-ic"><LucideIcon name="ArrowRight" size={16} /></span>
          </a>
          <a class="u-brand-outline u-btn-lg u-btn-split" href="#cum-functioneaza">
            Cum funcționează
            <span class="btn-ic"><LucideIcon name="Play" size={14} /></span>
          </a>
        </div>
      </div>

      <!-- Right: app screenshot mockup -->
      <div class="relative hidden lg:block">

        <!-- Glow behind the card -->
        <div class="pointer-events-none absolute -inset-4 rounded-3xl" style="background: radial-gradient(ellipse at 55% 45%, hsl(var(--color-lime) / 0.12) 0%, transparent 65%);"></div>

        <!-- App frame -->
        <div class="relative rounded-2xl overflow-hidden border" style="background: hsl(215 20% 8%); border-color: hsl(var(--color-border));">

          <!-- Browser chrome -->
          <div class="flex items-center gap-3 px-4 py-3 border-b" style="background: hsl(215 20% 6%); border-color: hsl(var(--color-border));">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500 opacity-70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500 opacity-70"></div>
              <div class="w-3 h-3 rounded-full opacity-70" style="background: var(--brand-color);"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div class="flex items-center gap-2 rounded-md px-3 py-1 text-xs font-mono border" style="background: hsl(var(--color-bg)); border-color: hsl(var(--color-border)); color: hsl(var(--color-muted));">
                <LucideIcon name="Lock" size={9} /> dashboard.coredigital.ro
              </div>
            </div>
          </div>

          <!-- App shell -->
          <div class="flex" style="height: 320px;">

            <!-- Sidebar -->
            <div class="w-44 flex-shrink-0 border-r p-3 flex flex-col gap-1" style="background: hsl(215 20% 7%); border-color: hsl(var(--color-border));">
              <!-- Logo area -->
              <div class="flex items-center gap-2 px-2 py-2 mb-2">
                <div class="w-6 h-6 rounded-md flex items-center justify-center" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                  <LucideIcon name="Zap" size={12} style="color: var(--brand-color);" />
                </div>
                <span class="text-xs font-semibold text-white">CoreDigital</span>
              </div>
              {[
                {icon: 'BarChart2', label: 'Dashboard', active: true},
                {icon: 'Monitor',   label: 'Website',   active: false},
                {icon: 'Star',      label: 'Review-uri',active: false},
                {icon: 'Sparkles',  label: 'AI Chatbot',active: false},
                {icon: 'Settings',  label: 'Setări',    active: false},
              ].map(item => (
                <div class={`flex items-center gap-2.5 px-2 py-1.5 rounded-lg text-xs ${item.active ? 'font-medium' : ''}`} style={item.active ? 'background: var(--brand-soft); color: var(--brand-color);' : 'color: hsl(var(--color-muted));'}>
                  <LucideIcon name={item.icon} size={13} />
                  {item.label}
                </div>
              ))}
            </div>

            <!-- Main content -->
            <div class="flex-1 p-4 overflow-hidden">
              <!-- Top row: title + badge -->
              <div class="flex items-center justify-between mb-4">
                <span class="text-sm font-semibold text-white">Overview</span>
                <span class="text-[0.6rem] font-mono px-2 py-0.5 rounded-full" style="background: hsl(142 70% 45% / 0.12); color: hsl(142 70% 60%); border: 1px solid hsl(142 70% 45% / 0.2);">● Live</span>
              </div>

              <!-- Stats cards -->
              <div class="grid grid-cols-3 gap-2.5 mb-4">
                {[
                  {label: 'Review-uri noi', val: '+47', delta: '+12%'},
                  {label: 'Rating Google',  val: '4.9★', delta: '+0.2'},
                  {label: 'Lead-uri AI',    val: '+23',  delta: '+8%'},
                ].map(s => (
                  <div class="rounded-xl p-3 border" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border));">
                    <p class="text-[0.6rem] font-mono mb-1" style="color: hsl(var(--color-muted));">{s.label}</p>
                    <p class="text-base font-semibold text-white">{s.val}</p>
                    <p class="text-[0.6rem] font-mono" style="color: var(--brand-color);">{s.delta}</p>
                  </div>
                ))}
              </div>

              <!-- Chart area (skeleton) -->
              <div class="rounded-xl border p-3" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border));">
                <div class="flex items-center justify-between mb-3">
                  <p class="text-[0.65rem] font-mono text-white">Activitate lunară</p>
                  <p class="text-[0.6rem] font-mono" style="color: hsl(var(--color-muted));">Ultimele 30 zile</p>
                </div>
                <!-- SVG chart bars -->
                <div class="flex items-end gap-1 h-14">
                  {[30,45,35,60,50,75,55,80,65,90,70,85,60,95,72,88,65,78,55,92,68,82,58,74,85,70,88,95,80,100].map((h, i) => (
                    <div class="flex-1 rounded-sm transition-all" style={`height: ${h * 0.56}px; background: ${i === 29 ? 'var(--brand-color)' : `hsl(var(--color-lime) / ${0.15 + h * 0.003})`};`}></div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating notification -->
        <div class="absolute -bottom-4 -left-4 flex items-center gap-2.5 rounded-xl border px-3 py-2" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border)); box-shadow: 0 8px 24px rgba(0,0,0,0.4);">
          <span class="w-2 h-2 rounded-full flex-shrink-0 animate-pulse" style="background: hsl(142 70% 50%);"></span>
          <div>
            <p class="text-xs font-semibold text-white leading-tight">Nou review primit</p>
            <p class="text-[0.6rem] font-mono" style="color: hsl(var(--color-muted));">★★★★★ · acum 3 min</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     PROBLEMS
     ============================================================ -->
<section class="py-20 lg:py-32" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="AlertTriangle" size={12} />
        Provocări reale
      </span>
      <h2 class="mb-4">Problemele business-urilor<br/>locale online</h2>
      <p class="max-w-xl mx-auto">
        Majoritatea afacerilor locale pierd clienți din cauza prezenței online inadecvate.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: hsl(0 70% 50% / 0.12); border: 1px solid hsl(0 70% 50% / 0.25);">
          <LucideIcon name="AlertOctagon" size={18} style="color: hsl(0 70% 60%);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Website-uri învechite</h3>
        <p class="text-sm leading-relaxed">
          Site-uri vechi, neoptimizate pentru mobil, care îndepărtează clienții potențiali și reduc încrederea în brand.
        </p>
      </div>

      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: hsl(38 92% 50% / 0.12); border: 1px solid hsl(38 92% 50% / 0.25);">
          <LucideIcon name="StarOff" size={18} style="color: hsl(38 92% 60%);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Lipsa review-urilor</h3>
        <p class="text-sm leading-relaxed">
          Clienții mulțumiți nu lasă review-uri, iar cei nemulțumiți influențează negativ reputația online.
        </p>
      </div>

      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: var(--sky-soft); border: 1px solid var(--sky-border);">
          <LucideIcon name="Clock" size={18} style="color: var(--sky-color);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Lipsa automatizării</h3>
        <p class="text-sm leading-relaxed">
          Ore pierdute cu răspunsuri la întrebări repetitive și procese manuale care pot fi automatizate.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     SERVICES OVERVIEW
     ============================================================ -->
<section id="servicii" class="py-20 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="Layers" size={12} />
        Soluțiile noastre
      </span>
      <h2 class="mb-4">Trei servicii esențiale,<br/>un singur partener</h2>
      <p class="max-w-xl mx-auto">
        Website, review-uri și AI chatbot — totul gestionat de CoreDigital, fără bătăi de cap.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Website -->
      <div class="u-card u-card-hover flex flex-col" data-service="website">
        <div class="u-service-icon mb-5">
          <LucideIcon name="Monitor" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">Website Modern</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Website profesional, optimizat pentru mobil, cu hosting și mentenanță incluse. Fără costuri ascunse.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--brand-color);">de la 200 RON/lună</span>
          <a href="/servicii/construire-website" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>

      <!-- Reviews -->
      <div class="u-card u-card-hover flex flex-col" data-service="reviews">
        <div class="u-service-icon mb-5">
          <LucideIcon name="Star" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">Colectare Review-uri</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Sistem automat de colectare și reactivare a clienților pentru a crește reputația online și încrederea.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--brand-color);">400 RON/lună</span>
          <a href="/servicii/recenzii-online" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>

      <!-- AI -->
      <div class="u-card u-card-hover flex flex-col" data-service="ai">
        <div class="u-service-icon mb-5">
          <LucideIcon name="MessagesSquare" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">AI Chatbot</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Asistent virtual inteligent care răspunde la întrebări și colectează lead-uri 24/7 pentru business-ul tău.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--sky-color);">100 RON/lună</span>
          <a href="/servicii/chatbot-ai" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     WEBSITE FOCUS
     ============================================================ -->
<section class="py-20 lg:py-32" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="u-service-pill mb-6 inline-flex" data-service="website">
          <LucideIcon name="Monitor" size={12} />
          Website Modern
        </span>
        <h2 class="mb-5">
          Website modern prin
          <span style="color: var(--brand-color);"> abonament lunar</span>
        </h2>
        <p class="mb-8">
          Fără investiții inițiale mari de mii de euro. Primești un website profesional, găzduire sigură și actualizări permanente pentru o taxă lunară predictibilă.
        </p>

        <div class="space-y-5 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Design responsiv modern</p>
              <p class="text-sm">Website care arată perfect pe orice dispozitiv, optimizat pentru conversie.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Găzduire și securitate premium</p>
              <p class="text-sm">Hosting rapid, certificat SSL și backup-uri automate pentru siguranță maximă.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Actualizări și mentenanță</p>
              <p class="text-sm">Menținem website-ul actualizat, securizat și funcțional permanent.</p>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <span class="font-mono text-xl font-semibold" style="color: var(--brand-color);">de la 200 RON/lună</span>
          <a href="/servicii/construire-website" class="u-brand-cta u-btn-sm">
            Află mai mult <LucideIcon name="ArrowRight" size={14} />
          </a>
        </div>
      </div>

      <!-- Browser mockup -->
      <div class="relative">
        <div class="rounded-xl border border-border overflow-hidden shadow-card" style="background: hsl(var(--color-surface-2));">
          <!-- Browser chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500 opacity-70"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500 opacity-70"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background: var(--brand-color); opacity: 0.7;"></div>
            </div>
            <div class="flex-1 ml-3">
              <div class="rounded-md px-3 py-1.5 flex items-center gap-2 max-w-xs border border-border" style="background: hsl(var(--color-bg));">
                <LucideIcon name="Lock" size={10} style="color: hsl(var(--color-muted));" />
                <span class="text-xs font-mono" style="color: hsl(var(--color-muted));">tuafacere.ro</span>
              </div>
            </div>
          </div>

          <!-- Website preview -->
          <div class="p-6">
            <div class="text-center mb-6">
              <div class="inline-block rounded-full px-3 py-1 text-xs font-mono mb-3" style="background: var(--brand-soft); color: var(--brand-color); border: 1px solid var(--brand-border);">
                Restaurant · Pensiune · Salon
              </div>
              <div class="h-5 rounded w-2/3 mx-auto mb-2" style="background: hsl(var(--color-border));"></div>
              <div class="h-3 rounded w-1/2 mx-auto mb-1" style="background: hsl(var(--color-border) / 0.6);"></div>
              <div class="h-3 rounded w-2/5 mx-auto mb-5" style="background: hsl(var(--color-border) / 0.4);"></div>

              <div class="flex justify-center gap-2 mb-6">
                <div class="rounded-lg px-4 py-1.5 text-xs font-semibold" style="background: var(--brand-color); color: hsl(220 14% 10%);">Programare</div>
                <div class="rounded-lg px-4 py-1.5 text-xs font-semibold border" style="border-color: var(--brand-border); color: var(--brand-color);">Contact</div>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-5">
              {[['Monitor', 'brand'], ['Clock', 'sky'], ['MapPin', 'brand']].map(([icon, accent]) => (
                <div class="rounded-lg p-3 border border-border" style={`background: hsl(var(--color-bg));`}>
                  <div class="w-6 h-6 rounded-md flex items-center justify-center mb-2" style={`background: var(--${accent}-soft); border: 1px solid var(--${accent}-border);`}>
                    <LucideIcon name={icon} size={12} style={`color: var(--${accent}-color);`} />
                  </div>
                  <div class="h-1.5 rounded w-3/4 mb-1" style="background: hsl(var(--color-border));"></div>
                  <div class="h-1.5 rounded w-1/2" style="background: hsl(var(--color-border) / 0.5);"></div>
                </div>
              ))}
            </div>

            <div class="rounded-lg h-20 flex items-center justify-center border border-border" style="background: hsl(var(--color-bg));">
              <LucideIcon name="Image" size={20} style="color: hsl(var(--color-border));" />
            </div>
          </div>
        </div>

        <!-- Phone mockup (animated scroll) -->
        <div class="absolute -bottom-8 -right-8 z-10 mobile-mockup">
          <div class="relative w-40" style="background: #111113; border-radius: 2.2rem; padding: 0.5rem; box-shadow: 0 25px 50px rgba(0,0,0,0.6), 0 0 0 1px hsl(var(--color-border));">
            <!-- Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-16 h-5 z-20" style="background: #111113; border-radius: 0 0 1rem 1rem;"></div>

            <div class="relative overflow-hidden" style="background: hsl(var(--color-bg)); border-radius: 1.75rem; height: 18rem;">
              <!-- Status bar -->
              <div class="absolute top-0 left-0 right-0 flex justify-between items-center px-3 py-2 z-10" style="background: hsl(var(--color-bg));">
                <span class="text-[0.6rem] font-semibold" style="color: hsl(var(--color-text));">9:41</span>
