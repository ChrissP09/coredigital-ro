---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/ui/LucideIcon.astro';
import ProcessSteps from '../components/ui/ProcessSteps.astro';
---

<BaseLayout
  title="CoreDigital - Prezență online completă pentru business-uri locale"
  description="Tot ce are nevoie un business local online, într-un singur abonament lunar. Website modern, colectare review-uri și AI chatbot pentru afacerea ta."
>

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="relative pt-36 pb-24 lg:pt-44 lg:pb-36 overflow-hidden">
  <!-- Ambient glow -->
  <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full opacity-20" style="background: radial-gradient(ellipse, hsl(var(--color-lime) / 0.25) 0%, transparent 70%);"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="u-section-tag mb-6 inline-flex">
          <LucideIcon name="Zap" size={12} />
          Prezență digitală completă
        </span>

        <h1 class="mb-6">
          Prezență online completă
          <span style="color: var(--brand-color);">prin abonament</span>
        </h1>

        <p class="text-lg mb-8 max-w-lg">
          Website modern, colectare review-uri automate și AI chatbot pentru business-ul tău local. Fără investiții inițiale mari, doar un abonament lunar predictibil.
        </p>

        <div class="flex flex-wrap gap-5 mb-10">
          <div class="flex items-center gap-2 text-sm" style="color: hsl(var(--color-muted));">
            <LucideIcon name="CheckCircle" size={15} style="color: var(--brand-color);" />
            Setup rapid
          </div>
          <div class="flex items-center gap-2 text-sm" style="color: hsl(var(--color-muted));">
            <LucideIcon name="CheckCircle" size={15} style="color: var(--brand-color);" />
            Abonament lunar
          </div>
          <div class="flex items-center gap-2 text-sm" style="color: hsl(var(--color-muted));">
            <LucideIcon name="CheckCircle" size={15} style="color: var(--brand-color);" />
            Cost predictibil
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a class="u-brand-cta u-btn-lg" href="/preturi">
            Vezi pachetele
            <LucideIcon name="ArrowRight" size={16} />
          </a>
          <a class="u-brand-outline u-btn-lg" href="#cum-functioneaza">
            <LucideIcon name="Play" size={15} />
            Cum funcționează
          </a>
        </div>
      </div>

      <!-- Hero panel -->
      <div class="relative">
        <div class="rounded-2xl border border-border p-6" style="background: hsl(var(--color-surface));">
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-xl border border-border p-5" style="background: hsl(var(--color-surface-2));">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-3" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <LucideIcon name="Monitor" size={16} style="color: var(--brand-color);" />
              </div>
              <p class="text-sm font-medium text-white mb-1">Website Modern</p>
              <p class="text-xs font-mono" style="color: var(--brand-color);">de la 200 RON/lună</p>
            </div>
            <div class="rounded-xl border border-border p-5" style="background: hsl(var(--color-surface-2));">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-3" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <LucideIcon name="Star" size={16} style="color: var(--brand-color);" />
              </div>
              <p class="text-sm font-medium text-white mb-1">Review-uri</p>
              <p class="text-xs font-mono" style="color: var(--brand-color);">400 RON/lună</p>
            </div>
            <div class="rounded-xl border border-border p-5" style="background: hsl(var(--color-surface-2));">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-3" style="background: var(--sky-soft); border: 1px solid var(--sky-border);">
                <LucideIcon name="MessagesSquare" size={16} style="color: var(--sky-color);" />
              </div>
              <p class="text-sm font-medium text-white mb-1">AI Chatbot</p>
              <p class="text-xs font-mono" style="color: var(--sky-color);">100 RON/lună</p>
            </div>
            <div class="rounded-xl border border-border p-5" style="background: hsl(var(--color-surface-2));">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-3" style="background: hsl(var(--color-border)); border: 1px solid hsl(var(--color-border));">
                <LucideIcon name="TrendingUp" size={16} style="color: hsl(var(--color-muted));" />
              </div>
              <p class="text-sm font-medium text-white mb-1">Rezultate</p>
              <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">Garantate</p>
            </div>
          </div>
        </div>

        <!-- Subtle ambient -->
        <div class="pointer-events-none absolute -bottom-8 -right-8 w-48 h-48 rounded-full opacity-10" style="background: radial-gradient(ellipse, var(--brand-color) 0%, transparent 70%);"></div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     PROBLEMS
     ============================================================ -->
<section class="py-20 lg:py-32" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="AlertTriangle" size={12} />
        Provocări reale
      </span>
      <h2 class="mb-4">Problemele business-urilor<br/>locale online</h2>
      <p class="max-w-xl mx-auto">
        Majoritatea afacerilor locale pierd clienți din cauza prezenței online inadecvate.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: hsl(0 70% 50% / 0.12); border: 1px solid hsl(0 70% 50% / 0.25);">
          <LucideIcon name="AlertOctagon" size={18} style="color: hsl(0 70% 60%);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Website-uri învechite</h3>
        <p class="text-sm leading-relaxed">
          Site-uri vechi, neoptimizate pentru mobil, care îndepărtează clienții potențiali și reduc încrederea în brand.
        </p>
      </div>

      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: hsl(38 92% 50% / 0.12); border: 1px solid hsl(38 92% 50% / 0.25);">
          <LucideIcon name="StarOff" size={18} style="color: hsl(38 92% 60%);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Lipsa review-urilor</h3>
        <p class="text-sm leading-relaxed">
          Clienții mulțumiți nu lasă review-uri, iar cei nemulțumiți influențează negativ reputația online.
        </p>
      </div>

      <div class="u-card u-card-hover">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background: var(--sky-soft); border: 1px solid var(--sky-border);">
          <LucideIcon name="Clock" size={18} style="color: var(--sky-color);" />
        </div>
        <h3 class="text-base font-semibold text-white mb-2">Lipsa automatizării</h3>
        <p class="text-sm leading-relaxed">
          Ore pierdute cu răspunsuri la întrebări repetitive și procese manuale care pot fi automatizate.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     SERVICES OVERVIEW
     ============================================================ -->
<section id="servicii" class="py-20 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="Layers" size={12} />
        Soluțiile noastre
      </span>
      <h2 class="mb-4">Trei servicii esențiale,<br/>un singur partener</h2>
      <p class="max-w-xl mx-auto">
        Website, review-uri și AI chatbot — totul gestionat de CoreDigital, fără bătăi de cap.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Website -->
      <div class="u-card u-card-hover flex flex-col" data-service="website">
        <div class="u-service-icon mb-5">
          <LucideIcon name="Monitor" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">Website Modern</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Website profesional, optimizat pentru mobil, cu hosting și mentenanță incluse. Fără costuri ascunse.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--brand-color);">de la 200 RON/lună</span>
          <a href="/servicii/construire-website" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>

      <!-- Reviews -->
      <div class="u-card u-card-hover flex flex-col" data-service="reviews">
        <div class="u-service-icon mb-5">
          <LucideIcon name="Star" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">Colectare Review-uri</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Sistem automat de colectare și reactivare a clienților pentru a crește reputația online și încrederea.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--brand-color);">400 RON/lună</span>
          <a href="/servicii/recenzii-online" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>

      <!-- AI -->
      <div class="u-card u-card-hover flex flex-col" data-service="ai">
        <div class="u-service-icon mb-5">
          <LucideIcon name="MessagesSquare" size={20} />
        </div>
        <h3 class="text-base font-semibold text-white mb-3">AI Chatbot</h3>
        <p class="text-sm leading-relaxed flex-1 mb-6">
          Asistent virtual inteligent care răspunde la întrebări și colectează lead-uri 24/7 pentru business-ul tău.
        </p>
        <div class="flex items-center justify-between pt-4 border-t border-border">
          <span class="font-mono text-sm font-semibold" style="color: var(--sky-color);">100 RON/lună</span>
          <a href="/servicii/chatbot-ai" class="text-xs font-medium flex items-center gap-1" style="color: hsl(var(--color-muted));">
            Detalii <LucideIcon name="ArrowRight" size={12} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     WEBSITE FOCUS
     ============================================================ -->
<section class="py-20 lg:py-32" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="u-service-pill mb-6 inline-flex" data-service="website">
          <LucideIcon name="Monitor" size={12} />
          Website Modern
        </span>
        <h2 class="mb-5">
          Website modern prin
          <span style="color: var(--brand-color);"> abonament lunar</span>
        </h2>
        <p class="mb-8">
          Fără investiții inițiale mari de mii de euro. Primești un website profesional, găzduire sigură și actualizări permanente pentru o taxă lunară predictibilă.
        </p>

        <div class="space-y-5 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Design responsiv modern</p>
              <p class="text-sm">Website care arată perfect pe orice dispozitiv, optimizat pentru conversie.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Găzduire și securitate premium</p>
              <p class="text-sm">Hosting rapid, certificat SSL și backup-uri automate pentru siguranță maximă.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Check" size={14} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">Actualizări și mentenanță</p>
              <p class="text-sm">Menținem website-ul actualizat, securizat și funcțional permanent.</p>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-4">
          <span class="font-mono text-xl font-semibold" style="color: var(--brand-color);">de la 200 RON/lună</span>
          <a href="/servicii/construire-website" class="u-brand-cta u-btn-sm">
            Află mai mult <LucideIcon name="ArrowRight" size={14} />
          </a>
        </div>
      </div>

      <!-- Browser mockup -->
      <div class="relative">
        <div class="rounded-xl border border-border overflow-hidden shadow-card" style="background: hsl(var(--color-surface-2));">
          <!-- Browser chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500 opacity-70"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500 opacity-70"></div>
              <div class="w-2.5 h-2.5 rounded-full" style="background: var(--brand-color); opacity: 0.7;"></div>
            </div>
            <div class="flex-1 ml-3">
              <div class="rounded-md px-3 py-1.5 flex items-center gap-2 max-w-xs border border-border" style="background: hsl(var(--color-bg));">
                <LucideIcon name="Lock" size={10} style="color: hsl(var(--color-muted));" />
                <span class="text-xs font-mono" style="color: hsl(var(--color-muted));">tuafacere.ro</span>
              </div>
            </div>
          </div>

          <!-- Website preview -->
          <div class="p-6">
            <div class="text-center mb-6">
              <div class="inline-block rounded-full px-3 py-1 text-xs font-mono mb-3" style="background: var(--brand-soft); color: var(--brand-color); border: 1px solid var(--brand-border);">
                Restaurant · Pensiune · Salon
              </div>
              <div class="h-5 rounded w-2/3 mx-auto mb-2" style="background: hsl(var(--color-border));"></div>
              <div class="h-3 rounded w-1/2 mx-auto mb-1" style="background: hsl(var(--color-border) / 0.6);"></div>
              <div class="h-3 rounded w-2/5 mx-auto mb-5" style="background: hsl(var(--color-border) / 0.4);"></div>

              <div class="flex justify-center gap-2 mb-6">
                <div class="rounded-lg px-4 py-1.5 text-xs font-semibold" style="background: var(--brand-color); color: hsl(220 14% 10%);">Programare</div>
                <div class="rounded-lg px-4 py-1.5 text-xs font-semibold border" style="border-color: var(--brand-border); color: var(--brand-color);">Contact</div>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-5">
              {[['Monitor', 'brand'], ['Clock', 'sky'], ['MapPin', 'brand']].map(([icon, accent]) => (
                <div class="rounded-lg p-3 border border-border" style={`background: hsl(var(--color-bg));`}>
                  <div class="w-6 h-6 rounded-md flex items-center justify-center mb-2" style={`background: var(--${accent}-soft); border: 1px solid var(--${accent}-border);`}>
                    <LucideIcon name={icon} size={12} style={`color: var(--${accent}-color);`} />
                  </div>
                  <div class="h-1.5 rounded w-3/4 mb-1" style="background: hsl(var(--color-border));"></div>
                  <div class="h-1.5 rounded w-1/2" style="background: hsl(var(--color-border) / 0.5);"></div>
                </div>
              ))}
            </div>

            <div class="rounded-lg h-20 flex items-center justify-center border border-border" style="background: hsl(var(--color-bg));">
              <LucideIcon name="Image" size={20} style="color: hsl(var(--color-border));" />
            </div>
          </div>
        </div>

        <!-- Mobile responsive badge -->
        <div class="absolute -bottom-4 -right-4 rounded-xl border border-border px-3 py-2 flex items-center gap-2 shadow-card" style="background: hsl(var(--color-surface));">
          <div class="w-5 h-5 rounded-md flex items-center justify-center" style="background: var(--brand-soft);">
            <LucideIcon name="Smartphone" size={11} style="color: var(--brand-color);" />
          </div>
          <span class="text-xs font-mono font-semibold" style="color: hsl(var(--color-text));">Mobile Ready</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     REVIEWS FOCUS
     ============================================================ -->
<section class="py-20 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Review panel -->
      <div class="u-card" data-service="reviews">
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="Star" size={18} style="color: var(--brand-color);" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Google Reviews</p>
              <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">Creștere automată</p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-2xl font-bold" style="color: var(--brand-color);">4.9</p>
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => (
                <LucideIcon name="Star" size={11} style="color: hsl(38 92% 55%); fill: hsl(38 92% 55%);" />
              ))}
            </div>
          </div>
        </div>

        <!-- Reviews marquee -->
        <div class="overflow-hidden rounded-xl border border-border" style="background: hsl(var(--color-bg));">
          <div class="reviews-marquee-mask p-3">
            <div class="reviews-marquee">
              <div class="reviews-marquee__group">
                {[
                  {init: 'A', text: '"Servicii excelente! Recomand cu încredere."', time: 'acum 2 zile'},
                  {init: 'M', text: '"Profesionalism și calitate. Mulțumim!"', time: 'acum 1 săptămână'},
                  {init: 'D', text: '"Foarte rapid și clar, totul automatizat. Super!"', time: 'acum 3 săptămâni'},
                  {init: 'I', text: '"Răspunsuri la review-uri și raportare lunară, impecabil."', time: 'acum 1 lună'},
                ].map(r => (
                  <article class="rounded-xl border border-border p-4 mb-3" style="background: hsl(var(--color-surface));">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div class="flex items-center gap-2.5">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs" style="background: var(--brand-soft); color: var(--brand-color); border: 1px solid var(--brand-border);">{r.init}</div>
                        <div>
                          <p class="text-xs font-semibold text-white">Client mulțumit</p>
                          <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">{r.time}</p>
                        </div>
                      </div>
                      <div class="flex gap-0.5">
                        {Array(5).fill(0).map(() => (
                          <LucideIcon name="Star" size={10} style="color: hsl(38 92% 55%); fill: hsl(38 92% 55%);" />
                        ))}
                      </div>
                    </div>
                    <p class="text-xs leading-relaxed" style="color: hsl(var(--color-muted));">{r.text}</p>
                  </article>
                ))}
              </div>
              <div class="reviews-marquee__group" aria-hidden="true">
                {[
                  {init: 'A', text: '"Servicii excelente! Recomand cu încredere."', time: 'acum 2 zile'},
                  {init: 'M', text: '"Profesionalism și calitate. Mulțumim!"', time: 'acum 1 săptămână'},
                  {init: 'D', text: '"Foarte rapid și clar, totul automatizat. Super!"', time: 'acum 3 săptămâni'},
                  {init: 'I', text: '"Răspunsuri la review-uri și raportare lunară, impecabil."', time: 'acum 1 lună'},
                ].map(r => (
                  <article class="rounded-xl border border-border p-4 mb-3" style="background: hsl(var(--color-surface));">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div class="flex items-center gap-2.5">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs" style="background: var(--brand-soft); color: var(--brand-color); border: 1px solid var(--brand-border);">{r.init}</div>
                        <div>
                          <p class="text-xs font-semibold text-white">Client mulțumit</p>
                          <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">{r.time}</p>
                        </div>
                      </div>
                      <div class="flex gap-0.5">
                        {Array(5).fill(0).map(() => (
                          <LucideIcon name="Star" size={10} style="color: hsl(38 92% 55%); fill: hsl(38 92% 55%);" />
                        ))}
                      </div>
                    </div>
                    <p class="text-xs leading-relaxed" style="color: hsl(var(--color-muted));">{r.text}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="mt-4 rounded-xl px-4 py-3 text-center text-sm font-semibold" style="background: var(--brand-soft); color: var(--brand-color); border: 1px solid var(--brand-border);">
          +127 review-uri noi luna aceasta
        </div>
      </div>

      <!-- Text -->
      <div>
        <span class="u-service-pill mb-6 inline-flex" data-service="reviews">
          <LucideIcon name="Star" size={12} />
          Recenzii Online
        </span>
        <h2 class="mb-5">
          Colectare și reactivare
