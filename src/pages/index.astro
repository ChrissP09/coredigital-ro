---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/ui/LucideIcon.astro';
import ProcessSteps from '../components/ui/ProcessSteps.astro';
---

<BaseLayout
  title="CoreDigital — Găsit, ales și contactat online. Prezență digitală completă."
  description="Construim și îmbunătățim constant website-ul, reputația online și vizibilitatea afacerii tale, astfel încât mai mulți oameni să te găsească și să te aleagă."
>

<!-- ============================================================
     HERO — Interactive Dashboard
     ============================================================ -->
<section class="hero-v2">

  <!-- Star canvas -->
  <canvas id="hero-star-canvas" aria-hidden="true"></canvas>

  <!-- Bottom fade -->
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, #071014, transparent); z-index:0;"></div>

  <!-- Centered copy -->
  <div class="hero-v2__copy">
    <div class="hero-v2__badge">
      <span class="hero-v2__badge-dot"></span>
      Creștem vizibilitatea afacerii tale online
    </div>
    <h1 class="hero-v2__heading">
      Ajutăm afacerea ta să fie <mark>găsită, aleasă</mark> și <mark>contactată</mark> online.
    </h1>
    <p class="hero-v2__sub">
      Construim și îmbunătățim constant website-ul, reputația online și vizibilitatea afacerii tale pentru a atrage mai mulți clienți și a genera mai multe oportunități.
    </p>
    <div class="hero-v2__actions">
      <a class="u-brand-cta u-btn-lg u-btn-split" href="#servicii">
        Vezi cum te putem ajuta
        <span class="btn-ic"><LucideIcon name="ArrowRight" size={16} /></span>
      </a>
      <a class="u-brand-outline u-btn-lg u-btn-split" href="/preturi">
        Vezi pachetele
        <span class="btn-ic"><LucideIcon name="Play" size={14} /></span>
      </a>
    </div>
  </div>

  <!-- Interactive Dashboard -->
  <div class="hero-dash-wrap">
    <div class="hero-dash-glow hero-dash-glow--l"></div>
    <div class="hero-dash-glow hero-dash-glow--r"></div>
    <div class="hero-dash-glow hero-dash-glow--b"></div>

    <div class="hero-dash">

      <!-- Browser chrome -->
      <div class="hero-dash__chrome">
        <div class="hero-dash__dots">
          <div class="hero-dash__dot" style="background:#ef4444;opacity:0.75;"></div>
          <div class="hero-dash__dot" style="background:#eab308;opacity:0.75;"></div>
          <div class="hero-dash__dot" style="background:var(--brand-color);opacity:0.75;"></div>
        </div>
        <div class="hero-dash__url">
          <div class="hero-dash__url-pill">
            <LucideIcon name="Lock" size={9} /> dashboard.coredigital.ro
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
          <div style="width:20px;height:20px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:hsl(var(--color-surface));border:1px solid hsl(var(--color-border));">
            <LucideIcon name="Bell" size={9} style="color:hsl(var(--color-muted));" />
          </div>
          <div style="width:20px;height:20px;border-radius:50%;background:var(--brand-soft);border:1px solid var(--brand-border);"></div>
        </div>
      </div>

      <!-- App shell -->
      <div class="dash-app">

        <!-- ── SIDEBAR ── -->
        <aside class="dash-sidebar">
          <div class="dash-logo-row">
            <div class="dash-logo-icon">
              <LucideIcon name="Zap" size={12} style="color:var(--brand-color);" />
            </div>
            <span class="dash-logo-name">CoreDigital</span>
          </div>
          <nav class="dash-nav" role="tablist" aria-label="Secțiuni">
            {[
              {id:'overview', icon:'BarChart2', label:'Prezentare generală'},
              {id:'website',  icon:'Monitor',   label:'Website'},
              {id:'google',   icon:'MapPin',    label:'Google Business'},
              {id:'recenzii', icon:'Star',      label:'Recenzii'},
              {id:'chatbot',  icon:'Sparkles',  label:'AI Chatbot'},
            ].map((item, i) => (
              <button
                class={`dash-nav__btn${i === 0 ? ' is-active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`panel-${item.id}`}
                data-tab={item.id}
              >
                <LucideIcon name={item.icon} size={13} />
                {item.label}
              </button>
            ))}
          </nav>
          <div class="dash-help-box">
            <div class="dash-help-inner">
              <p class="dash-help-title">Ai întrebări?</p>
              <p class="dash-help-sub">Suntem disponibili pentru orice problemă sau solicitare.</p>
              <a href="/contact" class="dash-help-link">
                Contactează-ne <LucideIcon name="ArrowRight" size={10} />
              </a>
            </div>
          </div>
        </aside>

        <!-- ── MAIN ── -->
        <div class="dash-main">

          <!-- Mobile tab bar -->
          <div class="dash-mobile-tabs" role="tablist">
            <div class="dash-mobile-tabs__row">
              {[
                {id:'overview', icon:'BarChart2', label:'Overview'},
                {id:'website',  icon:'Monitor',   label:'Website'},
                {id:'google',   icon:'MapPin',    label:'Google'},
                {id:'recenzii', icon:'Star',      label:'Recenzii'},
                {id:'chatbot',  icon:'Sparkles',  label:'AI Chat'},
              ].map((t, i) => (
                <button
                  class={`dash-mobile-tab${i === 0 ? ' is-active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls={`panel-${t.id}`}
                  data-tab={t.id}
                >
                  <LucideIcon name={t.icon} size={13} />
                  {t.label}
                </button>
              ))}
            </div>
          </div>

          <!-- Panels container -->
          <div class="dash-panels" id="dash-panels-container">

            <!-- ════ PANEL: Overview ════ -->
            <div id="panel-overview" class="dash-panel is-active" role="tabpanel">

              <div class="dp-header">
                <div>
                  <p class="dp-title">Prezentare generală</p>
                  <p class="dp-sub">Toate serviciile · Performanță combinată</p>
                </div>
                <div class="dp-controls">
                  <div class="dp-date-pill"><LucideIcon name="Calendar" size={9} /> Iunie 2025</div>
                  <div class="dp-online">● Online</div>
                </div>
              </div>

              <div class="dp-stats dp-stats--4" style="flex-shrink:0;">
                {[
                  {label:'Clienți noi',     cnt:'32', pre:'',  suf:'%', foot:'+32% față de mai'},
                  {label:'Review-uri noi',  cnt:'27', pre:'+', suf:'',  foot:'+8 față de mai'},
                  {label:'Cereri direcții', cnt:'18', pre:'+', suf:'',  foot:'vs. luna trecută'},
                  {label:'Apeluri primite', cnt:'43', pre:'+', suf:'%', foot:'+43% față de mai'},
                ].map((s, i) => (
                  <div class="dp-stat">
                    <p class="dp-stat__label">{s.label}</p>
                    <p class="dp-stat__value">{s.pre}<span data-count={s.cnt}>0</span>{s.suf}</p>
                    <svg class="dp-stat__sparkline" viewBox="0 0 60 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                      {i === 0 && <polyline points="0,16 10,12 20,13 30,7 40,9 50,4 60,2" stroke="hsl(83 78% 56% / 0.65)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>}
                      {i === 1 && <polyline points="0,15 10,11 22,13 32,7 42,9 52,5 60,3" stroke="hsl(83 78% 56% / 0.65)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>}
                      {i === 2 && <polyline points="0,14 12,10 22,12 32,6 44,8 52,4 60,2" stroke="hsl(83 78% 56% / 0.65)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>}
                      {i === 3 && <polyline points="0,16 8,13 18,14 28,9 36,11 46,5 60,3" stroke="hsl(83 78% 56% / 0.65)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>}
                    </svg>
                    <p class="dp-stat__foot">{s.foot}</p>
                  </div>
                ))}
              </div>

              <div class="dp-bottom" style="flex:1;min-height:0;">
                <!-- Activity -->
                <div class="dp-card">
                  <div class="dp-card__hd">
                    <span class="dp-card__ttl">Activitate recentă</span>
                    <span class="dp-card__meta">Ultimele 7 zile</span>
                  </div>
                  <div class="dp-feed">
                    {[
                      {bg:'hsl(38 92% 50% / 0.15)',  br:'hsl(38 92% 50% / 0.3)',   icon:'Star',    ic:'hsl(38 92% 60%)',   ttl:'Review 5★ de la Andrei M.', sub:'Happy Pets Veterinar',     t:'5 min'},
                      {bg:'hsl(217 91% 60% / 0.12)', br:'hsl(217 91% 60% / 0.25)', icon:'MapPin',  ic:'hsl(217 91% 65%)',  ttl:'Profil Google actualizat',  sub:'Program orar modificat',   t:'1 oră'},
                      {bg:'var(--brand-soft)',         br:'var(--brand-border)',      icon:'Zap',     ic:'var(--brand-color)',ttl:'3 oportunități noi găsite', sub:'Vezi recomandările AI',   t:'3 ore'},
                    ].map(a => (
                      <div class="dp-feed__item">
                        <div class="dp-feed__icon" style={`background:${a.bg};border:1px solid ${a.br};`}>
                          <LucideIcon name={a.icon} size={12} style={`color:${a.ic};`} />
                        </div>
                        <div class="dp-feed__body">
                          <p class="dp-feed__ttl">{a.ttl}</p>
                          <p class="dp-feed__sub">{a.sub}</p>
                        </div>
                        <span class="dp-feed__time">{a.t}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- Chart -->
                <div class="dp-card">
                  <div class="dp-card__hd">
                    <span class="dp-card__ttl">Vizibilitate online</span>
                    <span class="dp-card__meta">Ultimele 6 luni</span>
                  </div>
                  <div class="dp-chart">
                    <div class="dp-chart__inner">
                      <div class="dp-chart__badge">+68%</div>
                      <svg class="dp-chart__svg" viewBox="0 0 200 95" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                        <defs>
                          <linearGradient id="chartGradOv" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="hsl(83 78% 56%)" stop-opacity="0.7"/>
                            <stop offset="100%" stop-color="hsl(83 78% 56%)" stop-opacity="0"/>
                          </linearGradient>
                        </defs>
                        <text x="1"  y="14" font-size="7" fill="hsl(217 14% 45%)" font-family="monospace">100</text>
                        <text x="1"  y="38" font-size="7" fill="hsl(217 14% 45%)" font-family="monospace">75</text>
                        <text x="1"  y="62" font-size="7" fill="hsl(217 14% 45%)" font-family="monospace">50</text>
                        <text x="1"  y="86" font-size="7" fill="hsl(217 14% 45%)" font-family="monospace">25</text>
                        <line x1="24" y1="10" x2="200" y2="10" stroke="hsl(217 14% 22%)" stroke-width="0.5"/>
                        <line x1="24" y1="34" x2="200" y2="34" stroke="hsl(217 14% 22%)" stroke-width="0.5"/>
                        <line x1="24" y1="58" x2="200" y2="58" stroke="hsl(217 14% 22%)" stroke-width="0.5"/>
                        <line x1="24" y1="82" x2="200" y2="82" stroke="hsl(217 14% 22%)" stroke-width="0.5"/>
                        <path d="M24,78 C55,74 80,66 104,54 S148,32 168,22 S188,12 200,8 L200,88 L24,88 Z" fill="url(#chartGradOv)" opacity="0.3"/>
                        <path id="chart-line-overview" d="M24,78 C55,74 80,66 104,54 S148,32 168,22 S188,12 200,8"
                          stroke="hsl(83 78% 56%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"
                          style="stroke-dasharray:300;stroke-dashoffset:300;"/>
                        <circle cx="200" cy="8" r="3.5" fill="hsl(83 78% 56%)"/>
                        <circle cx="200" cy="8" r="6" fill="hsl(83 78% 56%)" opacity="0.2"/>
                      </svg>
                    </div>
                    <div class="dp-chart__xaxis">
                      {['Ian','Feb','Mar','Apr','Mai','Iun'].map(m => (
                        <span class="dp-chart__xl">{m}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- ════ PANEL: Website ════ -->
            <div id="panel-website" class="dash-panel" role="tabpanel">

              <div class="dp-header">
                <div>
                  <p class="dp-title">Performanță Website</p>
                  <p class="dp-sub">Core Web Vitals · Audit complet</p>
                </div>
                <div class="dp-controls">
                  <div class="dp-date-pill"><LucideIcon name="RefreshCw" size={9} /> Actualizat azi</div>
                </div>
              </div>

              <!-- Score ring + metric bars -->
              <div class="dp-score-row" style="flex-shrink:0;background:hsl(var(--color-surface));border:1px solid hsl(var(--color-border));border-radius:11px;padding:14px;margin-bottom:12px;">
                <div class="dp-score-ring">
                  <svg class="dp-score-ring__svg" viewBox="0 0 76 76">
                    <circle class="dp-score-ring__track" cx="38" cy="38" r="30"/>
                    <circle class="dp-score-ring__fill" id="score-ring-fill" cx="38" cy="38" r="30"
                      stroke-dasharray="188.5" stroke-dashoffset="188.5"/>
                  </svg>
                  <div class="dp-score-ring__label">
                    <span class="dp-score-ring__num" data-count="92">0</span>
                    <span class="dp-score-ring__max">/100</span>
                  </div>
                </div>
                <div class="dp-metrics">
                  {[
                    {label:'Performanță', val:98},
                    {label:'Mobil',       val:95},
                    {label:'SEO',         val:89},
                    {label:'Securitate',  val:94},
                  ].map(m => (
                    <div class="dp-metric">
                      <div class="dp-metric__row">
                        <span class="dp-metric__label">{m.label}</span>
                        <span class="dp-metric__val">{m.val}</span>
                      </div>
                      <div class="dp-metric__bar">
                        <div class="dp-metric__fill" data-width={`${m.val}%`} style="width:0%;"></div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="dp-bottom" style="flex:1;min-height:0;">
                <!-- Site preview -->
                <div class="dp-card">
                  <div class="dp-card__hd">
                    <span class="dp-card__ttl">Previzualizare site</span>
                    <span class="dp-card__meta" style="color:hsl(83 78% 60%);font-weight:600;">● Live</span>
                  </div>
                  <div class="dp-site-preview">
                    <div class="dp-site-preview__bar">
                      <div class="dp-site-dot" style="background:#ef4444;opacity:0.7;"></div>
                      <div class="dp-site-dot" style="background:#eab308;opacity:0.7;"></div>
                      <div class="dp-site-dot" style="background:var(--brand-color);opacity:0.7;"></div>
                      <span style="font-size:0.52rem;font-family:var(--font-mono);color:hsl(var(--color-muted));margin-left:6px;">www.afacereata.ro</span>
                    </div>
                    <div class="dp-site-preview__body" style="display:flex;flex-direction:column;gap:6px;">
                      <div style="height:4px;border-radius:4px;background:hsl(var(--color-border));width:65%;"></div>
                      <div style="height:3px;border-radius:4px;background:hsl(var(--color-border));width:82%;"></div>
                      <div style="height:3px;border-radius:4px;background:hsl(var(--color-border));width:50%;"></div>
                      <div style="height:22px;border-radius:6px;margin-top:4px;background:var(--brand-soft);border:1px solid var(--brand-border);width:42%;display:flex;align-items:center;justify-content:center;">
                        <span style="font-size:0.5rem;color:var(--brand-color);font-weight:600;">Contactează-ne</span>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Stats -->
                <div class="dp-card">
                  <div class="dp-card__hd"><span class="dp-card__ttl">Luna aceasta</span></div>
                  <div style="display:flex;flex-direction:column;gap:12px;flex:1;justify-content:center;">
                    {[
                      {label:'Vizitatori unici',     val:'1.847', foot:'+24%'},
                      {label:'Lead-uri generate',    val:'34',    foot:'+12 față de mai'},
                      {label:'Timp mediu pe site',   val:'3:42',  foot:'+18s față de mai'},
                    ].map(s => (
                      <div>
                        <p class="dp-stat__label">{s.label}</p>
                        <p class="dp-stat__value" style="font-size:0.95rem;">{s.val}</p>
                        <p class="dp-stat__foot">{s.foot}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

            </div>

            <!-- ════ PANEL: Google Business ════ -->
            <div id="panel-google" class="dash-panel" role="tabpanel">

              <div class="dp-header">
                <div>
                  <p class="dp-title">Google Business Profile</p>
                  <p class="dp-sub">Vizibilitate locală · Iunie 2025</p>
                </div>
                <div class="dp-controls">
                  <div class="dp-date-pill"><LucideIcon name="TrendingUp" size={9} /> +31% față de mai</div>
                </div>
              </div>

              <div class="dp-stats dp-stats--4" style="flex-shrink:0;">
                {[
                  {label:'Vizualizări profil', val:'1.284', foot:'+31% față de mai', lime:false},
                  {label:'Apeluri directe',    val:'37',    foot:'+8 față de mai',   lime:false},
                  {label:'Cereri direcții',    val:'29',    foot:'+11 față de mai',  lime:false},
                  {label:'Poziție locală',     val:'Top 3', foot:'Cuvinte cheie principale', lime:true},
                ].map(s => (
                  <div class="dp-stat">
                    <p class="dp-stat__label">{s.label}</p>
                    <p class="dp-stat__value" style={s.lime ? 'color:var(--brand-color);font-size:1rem;' : ''}>{s.val}</p>
                    <p class="dp-stat__foot">{s.foot}</p>
                  </div>
                ))}
              </div>

              <!-- Coverage map (full width) -->
              <div class="dp-coverage-map" style="flex:1;min-height:0;">
                <!-- City map background -->
                <img src="/media/city-map-bg.webp" alt="" class="dp-coverage-map__bg" aria-hidden="true" />
                <!-- Center glow -->
                <div class="dp-coverage-map__glow"></div>
                <!-- Header -->
                <div class="dp-coverage-map__hd">
                  <span class="dp-coverage-map__title">COVERAGE MAP</span>
                  <span class="dp-coverage-map__live">● Live</span>
                </div>
                <!-- 5×3 grid -->
                <div class="dp-cov-grid">
                  {[
                    {r:1,t:true}, {r:1,t:true}, {r:2,t:true}, {r:1,t:true}, {r:3,t:false},
                    {r:2,t:true}, {r:1,t:true}, {you:true},   {r:1,t:true}, {r:4,t:false},
                    {r:1,t:true}, {r:2,t:true}, {r:2,t:true}, {r:1,t:true}, {r:2,t:true},
                  ].map(c => c.you ? (
                    <div class="dp-cov-cell dp-cov-cell--you">
                      <span class="dp-cov-cell__pulse"></span>
                    </div>
                  ) : (
                    <div class={`dp-cov-cell ${c.t ? 'dp-cov-cell--top3' : 'dp-cov-cell--top5'}`}>
                      {c.r}
                    </div>
                  ))}
                </div>
                <!-- Legend -->
                <div class="dp-coverage-map__legend">
                  <span class="dp-cov-legend-item"><span class="dp-cov-legend-dot dp-cov-legend-dot--top3"></span> Top 3</span>
                  <span class="dp-cov-legend-item"><span class="dp-cov-legend-dot dp-cov-legend-dot--top5"></span> Top 5</span>
                  <span class="dp-cov-legend-item"><span class="dp-cov-legend-dot dp-cov-legend-dot--you"></span> Tu</span>
                </div>
              </div>

            </div>

            <!-- ════ PANEL: Recenzii ════ -->
            <div id="panel-recenzii" class="dash-panel" role="tabpanel">

              <div class="dp-header">
                <div>
                  <p class="dp-title">Reputație Online</p>
                  <p class="dp-sub">Google Reviews · Toate platformele</p>
                </div>
                <div class="dp-controls">
                  <div class="dp-date-pill" style="color:hsl(38 92% 60%);border-color:hsl(38 92% 50% / 0.3);">
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="hsl(38 92% 60%)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    4.9 medie
                  </div>
                </div>
              </div>

              <!-- Rating hero -->
              <div style="flex-shrink:0;display:grid;grid-template-columns:auto 1fr;gap:14px;background:hsl(var(--color-surface));border:1px solid hsl(var(--color-border));border-radius:11px;padding:14px;margin-bottom:12px;align-items:center;">
                <div>
                  <p class="dp-rating-num" data-count-float="4.9">0</p>
                  <div class="dp-stars">
                    {[1,2,3,4,5].map(() => (
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="hsl(38 92% 60%)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p class="dp-rating-sub">127 recenzii</p>
                </div>
                <div class="dp-rankings">
                  {[
                    {val:'+27',   label:'Recenzii noi\nluna aceasta', lime:true},
                    {val:'127',   label:'Total\nrecenzii',            lime:false},
                    {val:'100%',  label:'Rată de\nrăspuns',          lime:true},
                    {val:'4.9★',  label:'Medie\ngenerală',           lime:true},
                  ].map(r => (
                    <div class="dp-rank-item">
                      <p class={`dp-rank-item__val${r.lime ? ' dp-rank-item__val--lime' : ''}`}>{r.val}</p>
                      <p class="dp-rank-item__label">{r.label}</p>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Review cards -->
              <div style="display:flex;flex-direction:column;gap:8px;flex:1;overflow:hidden;">
                {[
                  {init:'AM', name:'Andrei M.', when:'acum 3 zile', text:'Servicii excelente! Am observat o creștere semnificativă a vizibilității online în primele 2 luni de colaborare.'},
                  {init:'MC', name:'Maria C.',  when:'acum 1 săptămână', text:'Echipă profesionistă și rezultate reale. Recomand cu căldură tuturor afacerilor locale!'},
                ].map(r => (
                  <div class="dp-review-card">
                    <div class="dp-review-card__top">
                      <div class="dp-review-card__author">
                        <div class="dp-review-card__av">{r.init}</div>
                        <span class="dp-review-card__name">{r.name}</span>
                      </div>
                      <div style="display:flex;align-items:center;gap:3px;">
                        {[1,2,3,4,5].map(() => (
