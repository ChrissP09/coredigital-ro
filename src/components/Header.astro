---
import LucideIcon from './ui/LucideIcon.astro';
const { pathname } = Astro.url;
const normalize = (path) => (path.length > 1 && path.endsWith('/') ? path.slice(0, -1) : path);
const current = normalize(pathname);
const isActive = (href) => current === normalize(href);
---

<header class="site-header fixed top-0 left-0 right-0 z-50">
  <div class="site-header__inner px-6 lg:px-8 h-18">
    <div class="flex items-center" style="height: 72px;">
      <a href="/" aria-label="CoreDigital" class="flex items-center">
        <img
          src="/core-digital-logo transparent.svg"
          alt="CoreDigital"
          class="h-8 w-auto"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigare principală">
      <div class="nav__item nav__item--has-children relative">
        <a
          class="nav__link inline-flex items-center gap-1.5"
          href="/servicii"
          aria-haspopup="true"
        >
          Servicii
          <LucideIcon name="ChevronDown" size={14} />
        </a>
        <ul class="nav__sublist">
          <li class="nav__subitem">
            <a class="nav__sublink" href="/servicii/construire-website">Website modern</a>
          </li>
          <li class="nav__subitem">
            <a class="nav__sublink" href="/servicii/recenzii-online">Recenzii online</a>
          </li>
          <li class="nav__subitem">
            <a class="nav__sublink" href="/servicii/chatbot-ai">Chatbot AI</a>
          </li>
        </ul>
      </div>

      <a
        class="nav__link"
        href="/preturi"
        aria-current={isActive('/preturi') ? 'page' : undefined}
      >
        Prețuri
      </a>

      <a
        class="nav__link"
        href="/despre-noi"
        aria-current={isActive('/despre-noi') ? 'page' : undefined}
      >
        Despre noi
      </a>

      <a
        class="u-brand-cta u-btn-sm"
        href="/contact"
        aria-current={isActive('/contact') ? 'page' : undefined}
      >
        Contact
        <LucideIcon name="ArrowRight" size={14} />
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button
      class="lg:hidden text-muted-400 hover:text-white transition-colors p-2"
      id="mobile-menu-button"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">Deschide meniul</span>
      <LucideIcon name="Menu" size={22} />
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="mobile-menu lg:hidden fixed inset-0 z-50 transform transition-transform duration-300 ease-in-out translate-x-full"
  aria-hidden="true"
>
  <div class="flex flex-col h-full p-6 pt-8">
    <div class="flex justify-between items-center mb-10">
      <a href="/" aria-label="CoreDigital">
        <img
          src="/core-digital-logo transparent.svg"
          alt="CoreDigital"
          class="h-7 w-auto"
          loading="eager"
          decoding="async"
        />
      </a>
      <button
        class="text-muted-400 hover:text-white transition-colors p-2"
        id="mobile-menu-close"
        type="button"
      >
        <span class="sr-only">Închide meniul</span>
        <LucideIcon name="X" size={22} />
      </button>
    </div>

    <nav class="flex flex-col gap-1" aria-label="Navigare mobilă">
      <a class="mobile-menu__link" href="/servicii">Servicii</a>
      <div class="pl-4 flex flex-col gap-1 mb-2">
        <a class="mobile-menu__sublink" href="/servicii/construire-website">Website modern</a>
        <a class="mobile-menu__sublink" href="/servicii/recenzii-online">Recenzii online</a>
        <a class="mobile-menu__sublink" href="/servicii/chatbot-ai">Chatbot AI</a>
      </div>
      <a class="mobile-menu__link" href="/preturi">Prețuri</a>
      <a class="mobile-menu__link" href="/despre-noi">Despre noi</a>
      <div class="mt-6">
        <a class="u-brand-cta" href="/contact">
          Contact
          <LucideIcon name="ArrowRight" size={14} />
        </a>
      </div>
    </nav>
  </div>
</div>
