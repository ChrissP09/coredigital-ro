<script>
/* ── Star canvas ── */
(function () {
  const canvas = document.getElementById('hero-star-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const SPACING = 96;
  let stars = [];

  function resize() {
    canvas.width  = canvas.parentElement.offsetWidth;
    canvas.height = canvas.parentElement.offsetHeight;
    buildStars();
  }

  function buildStars() {
    stars = [];
    const cols = Math.ceil(canvas.width  / SPACING) + 2;
    const rows = Math.ceil(canvas.height / SPACING) + 2;
    // exclusion zone in parent-relative coords (canvas top-left = parent top-left)
    const copyEl = canvas.parentElement.querySelector('.hero-v2__copy');
    let ex = null;
    if (copyEl) {
      const pRect = canvas.parentElement.getBoundingClientRect();
      const cRect = copyEl.getBoundingClientRect();
      const PAD   = 32;
      ex = { l: cRect.left - pRect.left - PAD, r: cRect.right  - pRect.left + PAD,
             t: cRect.top  - pRect.top  - PAD, b: cRect.bottom - pRect.top  + PAD };
    }
    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        if (Math.random() > 0.22) continue;
        const sx = col * SPACING + (Math.random() - 0.5) * 32;
        const sy = row * SPACING + (Math.random() - 0.5) * 32;
        if (ex && sx > ex.l && sx < ex.r && sy > ex.t && sy < ex.b) continue;
        stars.push({
          x: sx, y: sy,
          phase:    Math.random() * Math.PI * 2,
          speed:    0.25 + Math.random() * 0.55,
          maxAlpha: 0.45 + Math.random() * 0.55,
          radius:   0.8  + Math.random() * 1.0,
        });
      }
    }
  }

  function draw(now) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const t = now / 1000;
    for (const s of stars) {
      const alpha = s.maxAlpha * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
      ctx.shadowBlur  = s.radius * 12;
      ctx.shadowColor = `rgba(163,230,53,${alpha})`;
      ctx.fillStyle   = `rgba(163,230,53,${alpha})`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.shadowBlur = 0;
    requestAnimationFrame(draw);
  }

  resize();
  window.addEventListener('resize', resize, { passive: true });
  requestAnimationFrame(draw);
})();

/* ── Dashboard tabs ── */
(function () {
  const TABS = ['overview', 'website', 'google', 'recenzii', 'chatbot'];
  let current = 'overview';
  const animated = new Set();

  function switchTab(id) {
    if (id === current) return;
    TABS.forEach(tab => {
      const panel = document.getElementById('panel-' + tab);
      if (panel) {
        panel.classList.toggle('is-active', tab === id);
        panel.setAttribute('aria-hidden', tab !== id ? 'true' : 'false');
      }
    });
    document.querySelectorAll('[data-tab]').forEach(btn => {
      const active = btn.dataset.tab === id;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-selected', String(active));
    });
    current = id;
    if (!animated.has(id)) {
      animated.add(id);
      setTimeout(() => animatePanel(id), 60);
    }
    // scroll mobile tab into view
    const mobileTab = document.querySelector('.dash-mobile-tab.is-active');
    if (mobileTab) mobileTab.scrollIntoView({behavior:'smooth', block:'nearest', inline:'center'});
  }

  function animatePanel(id) {
    const panel = document.getElementById('panel-' + id);
    if (!panel) return;

    // Count-up integers
    panel.querySelectorAll('[data-count]').forEach(el => {
      const target = parseInt(el.dataset.count, 10);
      countUp(el, target, 900);
    });

    // Count-up float
    panel.querySelectorAll('[data-count-float]').forEach(el => {
      const target = parseFloat(el.dataset.countFloat);
      countUpFloat(el, target, 1100);
    });

    // Metric bar fill animation
    panel.querySelectorAll('.dp-metric__fill[data-width]').forEach(el => {
      el.style.width = el.dataset.width;
    });

    // Score ring animation
    const ring = panel.querySelector('#score-ring-fill');
    if (ring) {
      const circumference = 188.5;
      const offset = circumference - (92 / 100) * circumference;
      ring.style.transition = 'stroke-dashoffset 900ms cubic-bezier(0.22,1,0.36,1)';
      ring.style.strokeDashoffset = String(offset);
    }

    // Chart draw animation
    const chartLine = panel.querySelector('#chart-line-overview');
    if (chartLine) {
      chartLine.style.transition = 'stroke-dashoffset 1.3s cubic-bezier(0.22,1,0.36,1)';
      chartLine.style.strokeDashoffset = '0';
    }
  }

  function countUp(el, target, duration) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = String(target); return;
    }
    const start = performance.now();
    (function step(now) {
      const p = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(ease * target));
      if (p < 1) requestAnimationFrame(step);
    })(start);
  }

  function countUpFloat(el, target, duration) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target.toFixed(1); return;
    }
    const start = performance.now();
    (function step(now) {
      const p = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - p, 3);
      el.textContent = (ease * target).toFixed(1);
      if (p < 1) requestAnimationFrame(step);
    })(start);
  }

  function init() {
    // Wire all tab buttons
    document.querySelectorAll('[data-tab]').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
      btn.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); switchTab(btn.dataset.tab); }
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          const idx = TABS.indexOf(current);
          if (idx < TABS.length - 1) switchTab(TABS[idx + 1]);
        }
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          const idx = TABS.indexOf(current);
          if (idx > 0) switchTab(TABS[idx - 1]);
        }
      });
    });

    // Touch swipe on the panels container
    const container = document.getElementById('dash-panels-container');
    if (container) {
      let sx = 0, sy = 0;
      container.addEventListener('touchstart', e => {
        sx = e.touches[0].clientX; sy = e.touches[0].clientY;
      }, {passive: true});
      container.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - sx;
        const dy = e.changedTouches[0].clientY - sy;
        if (Math.abs(dx) < 40 || Math.abs(dy) > Math.abs(dx)) return;
        const idx = TABS.indexOf(current);
        if (dx < 0 && idx < TABS.length - 1) switchTab(TABS[idx + 1]);
        if (dx > 0 && idx > 0) switchTab(TABS[idx - 1]);
      }, {passive: true});
    }

    // Trigger overview animations when dashboard enters viewport
    const dash = document.querySelector('.hero-dash');
    if (dash && 'IntersectionObserver' in window) {
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          if (!animated.has('overview')) {
            animated.add('overview');
            animatePanel('overview');
          }
          obs.disconnect();
        }
      }, {threshold: 0.25});
      obs.observe(dash);
    } else {
      // fallback — run immediately
      if (!animated.has('overview')) { animated.add('overview'); animatePanel('overview'); }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


