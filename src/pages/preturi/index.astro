---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LucideIcon from '../../components/ui/LucideIcon.astro';
import PricingCombo from '../../components/ui/PricingCombo.astro';
---

<BaseLayout
  title="Prețuri | CoreDigital"
  description="Structură de prețuri pentru website, recenzii online și chatbot AI."
>
  <!-- Hero -->
  <section class="section section--l pricing-hero fade-in-up">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="pricing-hero__inner">
        <span class="website-hero__pill pricing-hero__pill" aria-label="Prețuri CoreDigital">
          <span class="website-hero__pill-icon" aria-hidden="true">
            <LucideIcon name="Wallet" size={16} />
          </span>
          <span class="website-hero__pill-text">Prețuri transparente</span>
        </span>

        <h1 class="pricing-hero__title">
          Prețuri și planuri <span class="u-gradient-text">transparente</span>
        </h1>
        <p class="pricing-hero__lead">
          Alege planul potrivit pentru afacerea ta, fără costuri ascunse. Poți începe cu un singur serviciu sau poți alege
          pachetul complet (All-in-One).
        </p>

        <div class="pricing-hero__trust" aria-label="Avantaje">
          <span class="pricing-hero__trust-item">
            <LucideIcon name="BadgeCheck" size={18} /> Fără costuri ascunse
          </span>
          <span class="pricing-hero__trust-item">
            <LucideIcon name="LifeBuoy" size={18} /> Suport inclus
          </span>
          <span class="pricing-hero__trust-item">
            <LucideIcon name="Timer" size={18} /> Lansare rapidă
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Toggle + Plans -->
  <section class="section section--s fade-in-up" id="planuri">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="pricing-toggle" aria-label="Tip plan">
        <span class="pricing-toggle__tab is-active" aria-current="true">Abonament lunar</span>
        <a class="pricing-toggle__tab" href="#preturi-personalizate">Plan personalizat</a>
      </div>

      <div class="pricing-panels">
        <div class="pricing-grid" role="list" aria-label="Planuri abonament">

          <!-- Card 1: AI Chatbot -->
          <article class="pricing-card" role="listitem">
            <div>
              <div class="pricing-card__icon">
                <LucideIcon name="Sparkles" size={18} style="color: var(--brand-color);" />
              </div>
              <p class="pricing-card__label">AI Chatbot</p>
              <h3 class="pricing-card__name">Agent AI Chatbot</h3>
              <p class="pricing-card__desc">Răspuns non-stop, colectare lead-uri și suport instant direct pe website.</p>
            </div>

            <div class="pricing-card__divider"></div>

            <div class="pricing-card__price">
              <span class="pricing-card__amount">100</span>
              <span class="pricing-card__period">RON / lună</span>
            </div>

            <a class="pricing-ghost-btn pricing-card__cta-btn" href="/contact">Activează serviciul</a>

            <ul class="pricing-card__list">
              {['text / voce / combinat', 'colectare date de contact', 'calificare lead-uri', '* cost suplimentar mic în funcție de utilizare'].map(f => (
                <li class="pricing-card__feat">
                  <span class="pricing-card__check"><LucideIcon name="Check" size={10} style="color: var(--brand-color);" /></span>
                  {f}
                </li>
              ))}
            </ul>
          </article>

          <!-- Card 2: Website — featured -->
          <article class="pricing-card pricing-card--popular" role="listitem">
            <div class="pricing-card__badge">
              <LucideIcon name="Zap" size={11} /> Cel mai popular
            </div>

            <div>
              <div class="pricing-card__icon pricing-card__icon--featured">
                <LucideIcon name="Monitor" size={18} style="color: var(--brand-color);" />
              </div>
              <p class="pricing-card__label" style="color: var(--brand-color);">Website</p>
              <h3 class="pricing-card__name">Creare website</h3>
              <p class="pricing-card__desc">Website modern pe abonament, fără cost inițial. Design premium, conversii, SEO.</p>
            </div>

            <div class="pricing-card__divider"></div>

            <div class="pricing-card__price">
              <span class="pricing-card__amount">300</span>
              <span class="pricing-card__period">RON / lună</span>
            </div>

            <a class="u-brand-cta pricing-card__cta-btn" href="/contact">Activează serviciul</a>

            <ul class="pricing-card__list">
              {['design premium + responsive', 'lansare rapidă + mentenanță', 'copy clar + structură conversie', 'suport continuu'].map(f => (
                <li class="pricing-card__feat" style="color: hsl(var(--color-text));">
                  <span class="pricing-card__check"><LucideIcon name="Check" size={10} style="color: var(--brand-color);" /></span>
                  {f}
                </li>
              ))}
            </ul>
          </article>

          <!-- Card 3: Recenzii -->
          <article class="pricing-card" role="listitem">
            <div>
              <div class="pricing-card__icon">
                <LucideIcon name="Star" size={18} style="color: var(--brand-color);" />
              </div>
              <p class="pricing-card__label">Recenzii</p>
              <h3 class="pricing-card__name">Colectare recenzii Google</h3>
              <p class="pricing-card__desc">Crești încrederea și vizibilitatea cu un flux automat pentru recenzii reale și monitorizare.</p>
            </div>

            <div class="pricing-card__divider"></div>

            <div class="pricing-card__price">
              <span class="pricing-card__amount">400</span>
              <span class="pricing-card__period">RON / lună</span>
            </div>

            <a class="pricing-ghost-btn pricing-card__cta-btn" href="/contact">Activează serviciul</a>

            <ul class="pricing-card__list">
              {['flux automat de recenzii', 'protejare reputație', 'raportare & optimizare', 'suport inclus'].map(f => (
                <li class="pricing-card__feat">
                  <span class="pricing-card__check"><LucideIcon name="Check" size={10} style="color: var(--brand-color);" /></span>
                  {f}
                </li>
              ))}
            </ul>
          </article>

          <div class="pricing-grid__combo" role="listitem">
            <PricingCombo
              label="Ofertă limitată"
              title="Pachetul All-in-One"
              description={`Obții acces simultan la toate cele 3 servicii: website, recenzii și AI Chatbot. Ideal dacă vrei un sistem complet care atrage, convinge și convertește.`}
              perks={['Website + mentenanță', 'Recenzii Google', 'AI Chatbot', 'Integrare completă']}
              oldPrice="1.100 RON"
              price="700 RON"
              period="/ lună"
              ctaText="Activează All-in-One"
              ctaHref="/contact"
              note="Facturare lunară. Suport inclus."
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section--s fade-in-up">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div id="preturi-personalizate" class="page__cta pricing-final" aria-labelledby="pricing-cta">
        <div class="pricing-final__icon" aria-hidden="true">
          <LucideIcon name="MessageCircle" size={22} />
        </div>
        <h2 id="pricing-cta" class="page__section-title">Ai nevoie de o soluție personalizată?</h2>
        <p class="page__lead" style="max-width: 48ch;">
          Discutăm despre nevoile tale și construim un plan potrivit, indiferent de dimensiunea business-ului.
        </p>
        <a class="u-brand-cta u-btn-lg" href="/contact">
          Hai să discutăm <LucideIcon name="ArrowRight" size={18} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
