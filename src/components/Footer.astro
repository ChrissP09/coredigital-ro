---
import LucideIcon from './ui/LucideIcon.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-border" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid md:grid-cols-4 gap-12">

      <!-- Brand -->
      <div>
        <a href="/" aria-label="CoreDigital" class="inline-block mb-5">
          <img
            src="/core-digital-logo transparent.svg"
            alt="CoreDigital"
            class="h-7 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-sm leading-relaxed" style="color: hsl(var(--color-muted));">
          Tot ce are nevoie un business local online,<br/>într-un singur abonament lunar.
        </p>
      </div>

      <!-- Servicii -->
      <div>
        <p class="u-label mb-5" style="color: hsl(var(--color-muted));">Servicii</p>
        <ul class="space-y-3 text-sm" style="color: hsl(var(--color-muted));">
          <li>
            <a class="hover:text-white transition-colors" href="/servicii/construire-website">Website modern</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/servicii/recenzii-online">Recenzii online</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/servicii/chatbot-ai">Chatbot AI</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/preturi">Prețuri</a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="u-label mb-5" style="color: hsl(var(--color-muted));">Companie</p>
        <ul class="space-y-3 text-sm" style="color: hsl(var(--color-muted));">
          <li>
            <a class="hover:text-white transition-colors" href="/despre-noi">Despre noi</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/contact">Contact</a>
          </li>
          <li>
            <a class="hover:text-white transition-colors" href="/intrebari-frecvente">Întrebări frecvente</a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="u-label mb-5" style="color: hsl(var(--color-muted));">Contact</p>
        <ul class="space-y-3 text-sm" style="color: hsl(var(--color-muted));">
          <li class="flex items-center gap-2.5">
            <LucideIcon name="Mail" size={14} />
            <a href="mailto:contact@coredigital.ro" class="hover:text-white transition-colors">
              contact@coredigital.ro
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <LucideIcon name="Phone" size={14} />
            <a href="tel:+407XXXXXXXX" class="hover:text-white transition-colors">
              +40 7XX XXX XXX
            </a>
          </li>
        </ul>

        <div class="flex gap-3 mt-6">
          <a
            href="#"
            aria-label="Facebook"
            class="w-9 h-9 rounded-lg border border-border flex items-center justify-center transition-colors hover:border-brand-border"
            style="color: hsl(var(--color-muted));"
          >
            <LucideIcon name="Facebook" size={15} />
          </a>
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-9 h-9 rounded-lg border border-border flex items-center justify-center transition-colors hover:border-brand-border"
            style="color: hsl(var(--color-muted));"
          >
            <LucideIcon name="Linkedin" size={15} />
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-border mt-14 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs" style="color: hsl(var(--color-muted));">
        © {year} CoreDigital. Toate drepturile rezervate.
      </p>
      <p class="text-xs font-mono" style="color: hsl(var(--color-muted) / 0.5);">
        Construit cu grijă pentru business-uri locale
      </p>
    </div>
  </div>
</footer>
