                <p class="text-xs mt-0.5" style="color: hsl(var(--color-muted));">Feedback trimis direct la echipa ta. Fără review-uri negative pe Google.</p>
              </div>
            </div>

            <div id="ff-result-public" class="rounded-xl border p-4 flex items-start gap-3" style="position: absolute; inset: 0; background: hsl(var(--color-surface-2)); border-color: var(--brand-border); opacity: 0; transition: opacity 0.3s ease; pointer-events: none;">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="hsl(83 78% 56%)" stroke="hsl(83 78% 56%)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Recenzie Publică pe Google</p>
                <p class="text-xs mt-0.5" style="color: hsl(var(--color-muted));">Redirecționat direct spre Google Business Profile. Live în câteva minute.</p>
              </div>
            </div>

          </div>

        </div>
      </div>

      <script>
        (function() {
          const stars = document.querySelectorAll('.ff-star');
          const hint = document.getElementById('ff-hint');
          const lowLabel = document.getElementById('ff-low-label');
          const highLabel = document.getElementById('ff-high-label');
          const privateCard = document.getElementById('ff-result-private');
          const publicCard = document.getElementById('ff-result-public');

          function showPath(rating) {
            const isLow = rating <= 3;

            // Stars visual
            stars.forEach(s => {
              const n = parseInt(s.dataset.star);
              const svg = s.querySelector('svg');
              if (n <= rating) {
                svg.setAttribute('fill', 'hsl(38 92% 55%)');
                svg.setAttribute('stroke', 'hsl(38 92% 55%)');
              } else {
                svg.setAttribute('fill', 'none');
                svg.setAttribute('stroke', 'hsl(var(--color-border))');
              }
            });

            // Labels
            lowLabel.style.opacity  = isLow  ? '1' : '0.35';
            highLabel.style.opacity = !isLow ? '1' : '0.35';
            lowLabel.style.borderColor  = isLow  ? 'hsl(0 80% 55% / 0.5)' : 'hsl(var(--color-border))';
            highLabel.style.borderColor = !isLow ? 'var(--brand-border)' : 'hsl(var(--color-border))';

            // Result cards — opacity only, no layout shift
            privateCard.style.opacity = isLow ? '1' : '0';
            privateCard.style.pointerEvents = isLow ? 'auto' : 'none';
            publicCard.style.opacity = isLow ? '0' : '1';
            publicCard.style.pointerEvents = isLow ? 'none' : 'auto';

            hint.textContent = isLow
              ? `${rating} ste${rating === 1 ? 'a' : 'le'} — feedback privat către echipa ta`
              : `${rating} stele — redirecționat spre Google Reviews`;
          }

          // Auto-demo cycle
          let step = 0;
          const demo = [5, 5, 4, 4, 2, 1, 5, 5];
          function autoCycle() {
            showPath(demo[step % demo.length]);
            step++;
          }
          autoCycle();
          const interval = setInterval(autoCycle, 1800);

          // Manual override
          stars.forEach(btn => {
            btn.addEventListener('click', () => {
              clearInterval(interval);
              showPath(parseInt(btn.dataset.star));
            });
            btn.addEventListener('mouseenter', () => {
              clearInterval(interval);
              showPath(parseInt(btn.dataset.star));
            });
          });
        })();
      </script>

      <!-- Right: copy -->
      <div>
        <span class="u-section-tag mb-6 inline-flex">
          <LucideIcon name="ShieldCheck" size={12} />
          Protecție Reputație
        </span>
        <h2 class="mb-5">Filtrare <span style="color: var(--brand-color);">Inteligentă</span></h2>
        <p class="mb-8" style="color: hsl(var(--color-muted)); line-height: 1.7;">
          Protejează-ți reputația captând clienții nemulțumiți înainte să posteze public. Direcționăm feedback-ul negativ către suport, iar clienții fericiți — direct pe Google.
        </p>
        <div class="space-y-5">
          {[
            {icon: 'Lock', title: 'Rezoluție Privată', desc: 'Rezolvi problemele intern, fără review-uri negative. Clienții nemulțumiți completează un formular privat către echipa ta.'},
            {icon: 'Bell', title: 'Alerte Instante', desc: 'Primești notificare imediat ce apare un feedback negativ. Reacționezi rapid și rezolvi problema înainte să escaladeze.'},
          ].map(item => (
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <LucideIcon name={item.icon} size={15} style="color: var(--brand-color);" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white mb-1">{item.title}</p>
                <p class="text-sm" style="color: hsl(var(--color-muted));">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

