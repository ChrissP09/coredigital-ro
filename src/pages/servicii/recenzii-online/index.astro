---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LucideIcon from '../../../components/ui/LucideIcon.astro';
---

<BaseLayout
  title="Colectare recenzii online | CoreDigital"
  description="Transformă clienții mulțumiți în recenzii Google care aduc clienți noi. Sistem automat de colectare recenzii pentru afaceri locale."
>

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="relative overflow-hidden" style="background: hsl(var(--color-bg)); padding-top: 7rem; padding-bottom: 5rem;">

  <!-- Wave/curve SVG pattern — lime on dark -->
  <div class="pointer-events-none absolute inset-0" style="background-image: url(\"data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%20720'%3E%3Cg%20fill='none'%20stroke='%23a3e635'%20stroke-opacity='0.1'%20stroke-width='1'%3E%3Cpath%20d='M-120%20110%20C%20120%2040%20320%2040%20520%20110%20S%20920%20180%201320%20110'/%3E%3Cpath%20d='M-120%20250%20C%20160%20180%20360%20180%20560%20250%20S%20960%20320%201320%20250'/%3E%3Cpath%20d='M-120%20390%20C%20200%20320%20400%20320%20600%20390%20S%201000%20460%201320%20390'/%3E%3Cpath%20d='M-120%20530%20C%20240%20460%20440%20460%20640%20530%20S%201040%20600%201320%20530'/%3E%3C/g%3E%3Cg%20fill='none'%20stroke='%23a3e635'%20stroke-opacity='0.07'%20stroke-width='1'%3E%3Cpath%20d='M260%20-120%20C%20330%20110%20330%20300%20260%20510%20S%20190%20910%20260%20840'/%3E%3Cpath%20d='M460%20-120%20C%20530%2090%20530%20280%20460%20490%20S%20390%20890%20460%20840'/%3E%3Cpath%20d='M660%20-120%20C%20730%2070%20730%20260%20660%20470%20S%20590%20870%20660%20840'/%3E%3Cpath%20d='M860%20-120%20C%20930%2060%20930%20250%20860%20460%20S%20790%20860%20860%20840'/%3E%3C/g%3E%3C/svg%3E\"); background-size: cover; opacity: 0.5;"></div>

  <!-- Gradient blobs -->
  <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px]" style="background: radial-gradient(ellipse 55% 55% at 50% 0%, hsl(var(--color-lime) / 0.16) 0%, transparent 70%);"></div>
  <div class="pointer-events-none absolute top-1/3 -right-24 w-[400px] h-[320px]" style="background: radial-gradient(ellipse at 80% 50%, hsl(var(--color-lime) / 0.07) 0%, transparent 65%);"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to top, hsl(var(--color-bg)), transparent);"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="website-hero__pill mb-6 inline-flex" aria-label="Serviciu: Recenzii">
          <span class="website-hero__pill-icon"><LucideIcon name="Star" size={16} /></span>
          <span class="website-hero__pill-text">Colectare Recenzii</span>
        </span>

        <h1 class="mb-6" style="letter-spacing: -0.03em; line-height: 1.06;">
          Transformă clienții mulțumiți în recenzii care aduc
          <span style="color: var(--brand-color);"> clienți noi</span>
        </h1>

        <p class="mb-8 max-w-lg" style="color: hsl(var(--color-muted)); font-size: 1.05rem; line-height: 1.7;">
          Mai mulți oameni aleg afaceri cu multe recenzii pozitive. Îi ajutăm pe clienții tăi să lase recenzii, simplu și automat, fără să ridici un deget.
        </p>

        <div class="flex flex-wrap gap-3 mb-10">
          {[
            {icon: 'Zap', label: 'Automatizat 100%'},
            {icon: 'ShieldCheck', label: 'Protecție rating'},
            {icon: 'TrendingUp', label: 'Rezultate în 14 zile'},
          ].map(f => (
            <span class="inline-flex items-center gap-2 text-sm px-3 py-1.5 rounded-full border" style="background: hsl(var(--color-surface) / 0.6); border-color: hsl(var(--color-border)); color: hsl(var(--color-muted)); backdrop-filter: blur(8px);">
              <LucideIcon name={f.icon} size={13} style="color: var(--brand-color);" />
              {f.label}
            </span>
          ))}
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="u-brand-cta u-btn-lg u-btn-split" href="/contact">
            Vreau mai multe recenzii
            <span class="btn-ic"><LucideIcon name="ArrowUpRight" size={16} /></span>
          </a>
          <a class="u-brand-outline u-btn-lg u-btn-split" href="#proces">
            Vezi cum funcționează
            <span class="btn-ic"><LucideIcon name="ChevronDown" size={16} /></span>
          </a>
        </div>
      </div>

      <!-- Right: Google Reviews mockup -->
      <div class="relative">
        <div class="pointer-events-none absolute -inset-4 rounded-3xl" style="background: radial-gradient(ellipse at 60% 50%, hsl(var(--color-lime) / 0.1) 0%, transparent 65%);"></div>

        <div class="relative rounded-2xl border p-6" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border));">

          <!-- Header -->
          <div class="flex items-center justify-between mb-6 pb-5 border-b" style="border-color: hsl(var(--color-border));">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <LucideIcon name="Star" size={18} style="color: var(--brand-color);" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Google Reviews</p>
                <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">Recenzii verificate</p>
              </div>
            </div>
            <span class="text-xs font-mono px-2 py-0.5 rounded-full" style="background: hsl(142 70% 45% / 0.12); color: hsl(142 70% 60%); border: 1px solid hsl(142 70% 45% / 0.25);">● Live</span>
          </div>

          <!-- Rating display -->
          <div class="text-center mb-6 pb-6 border-b" style="border-color: hsl(var(--color-border));">
            <p class="text-5xl font-semibold text-white mb-2" style="letter-spacing: -0.04em;">4.9</p>
            <div class="flex justify-center gap-1 mb-2">
              {Array(5).fill(0).map(() => (
                <LucideIcon name="Star" size={18} style="color: hsl(38 92% 55%); fill: hsl(38 92% 55%);" class="star-animate" />
              ))}
            </div>
            <p class="text-xs font-mono" style="color: hsl(var(--color-muted));">Din 187 recenzii · +12 luna asta</p>
          </div>

          <!-- Recent reviews -->
          <div class="space-y-3">
            {[
              {init: 'M', name: 'Maria P.', text: '"Experiență excelentă! Recomand cu încredere."', time: 'acum 2 ore'},
              {init: 'I', name: 'Ion D.', text: '"Servicii de top! Mulțumit de rezultate."', time: 'ieri'},
              {init: 'A', name: 'Alina C.', text: '"Rapid și profesionist. Exact ce căutam."', time: 'acum 3 zile'},
            ].map(r => (
              <div class="flex items-start gap-3 rounded-xl p-3 border" style="background: hsl(var(--color-surface-2)); border-color: hsl(var(--color-border));">
                <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0" style="background: var(--brand-soft); border: 1px solid var(--brand-border); color: var(--brand-color);">{r.init}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1">
                    <p class="text-xs font-semibold text-white">{r.name}</p>
                    <p class="text-[0.65rem] font-mono" style="color: hsl(var(--color-muted));">{r.time}</p>
                  </div>
                  <div class="flex gap-0.5 mb-1">
                    {Array(5).fill(0).map(() => <LucideIcon name="Star" size={10} style="color: hsl(38 92% 55%); fill: hsl(38 92% 55%);" />)}
                  </div>
                  <p class="text-xs" style="color: hsl(var(--color-muted));">{r.text}</p>
                </div>
              </div>
            ))}
          </div>

        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -right-4 flex items-center gap-2 rounded-xl border px-3 py-2" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border)); box-shadow: 0 8px 24px rgba(0,0,0,0.4);">
          <LucideIcon name="ShieldCheck" size={14} style="color: var(--brand-color);" />
          <div>
            <p class="text-xs font-semibold text-white leading-tight">Rezultate în 7-14 zile</p>
            <p class="text-[0.6rem] font-mono" style="color: hsl(var(--color-muted));">Automatizat 100%</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ============================================================
     PROBLEME
     ============================================================ -->
<section class="py-20 lg:py-32 fade-in-up" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="AlertTriangle" size={12} />
        Problema reală
      </span>
      <h2 class="mb-4">De ce nu ai recenzii, deși<br/>clienții sunt mulțumiți?</h2>
      <p class="max-w-2xl mx-auto" style="color: hsl(var(--color-muted));">
        Clienții tăi sunt fericiți, dar nimeni nu lasă recenzii. Iar când caută alții pe Google, aleg concurența care pare mai de încredere — doar pentru că are mai multe stele.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {[
        {icon: 'Brain', title: 'Clienții uită să lase recenzie', desc: 'Au fost mulțumiți, dar nu li se pare urgent. Au plecat și au uitat complet.', color: 'red'},
        {icon: 'MapPin', title: 'Nu știu unde să lase recenzie', desc: 'Ar vrea să ajute, dar nu știu cum să ajungă pe pagina de Google Reviews. E prea complicat.', color: 'amber'},
        {icon: 'AlertOctagon', title: 'Lipsesc recenziile pozitive', desc: 'Clienții nemulțumiți lasă recenzii din impuls. Cei mulțumiți — nu. Rating scăzut, deși serviciul e bun.', color: 'red'},
        {icon: 'TrendingUp', title: 'Pierzi clienți înainte să-i cunoști', desc: '78% din oameni citesc recenziile înainte să aleagă o afacere. Fără recenzii, ești invizibil.', color: 'amber'},
      ].map(p => (
        <div class="u-card flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style={`background: hsl(${p.color === 'red' ? '0 80% 55%' : '38 92% 55%'} / 0.1); border: 1px solid hsl(${p.color === 'red' ? '0 80% 55%' : '38 92% 55%'} / 0.2);`}>
            <LucideIcon name={p.icon} size={18} style={`color: hsl(${p.color === 'red' ? '0 80% 60%' : '38 92% 60%'});`} />
          </div>
          <div>
            <h3 class="text-sm font-semibold text-white mb-1">{p.title}</h3>
            <p class="text-sm" style="color: hsl(var(--color-muted));">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     SOLUȚIA — CUM FUNCȚIONEAZĂ
     ============================================================ -->
<section class="py-20 lg:py-32 fade-in-up" id="proces">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <span class="u-section-tag mb-6 inline-flex">
          <LucideIcon name="Zap" size={12} />
          Cum funcționează
        </span>
        <h2 class="mb-5">Sistem automat care transformă clienții mulțumiți în
          <span style="color: var(--brand-color);"> recenzii Google</span>
        </h2>
        <p class="mb-8" style="color: hsl(var(--color-muted)); line-height: 1.7;">
          Nu mai rogi clienții manual. Nu mai trimiți mesaje individuale. Nu mai aștepți și speri.
        </p>

        <div class="space-y-5">
          {[
            {icon: 'Clock', title: 'Momentul perfect', desc: 'Solicităm recenzia când clientul e încă entuziasmat, nu peste 3 luni când a uitat totul.'},
            {icon: 'ArrowRight', title: 'Link direct, fără complicații', desc: 'Clientul dă click, vede Google, lasă recenzia. Fără căutări, fără confuzii.'},
            {icon: 'ShieldCheck', title: 'Filtrare inteligentă', desc: 'Dacă clientul e nemulțumit, îl direcționăm către tine direct — nu către Google. Protejăm ratingul.'},
            {icon: 'CheckCircle', title: 'Tu nu faci nimic', desc: 'Sistem automatizat complet. Tu vezi doar notificări: "Ai primit o recenzie nouă".'},
          ].map(item => (
            <div class="flex items-start gap-4">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
                <LucideIcon name={item.icon} size={15} style="color: var(--brand-color);" />
              </div>
              <div>
                <p class="text-sm font-semibold text-white mb-1">{item.title}</p>
                <p class="text-sm" style="color: hsl(var(--color-muted));">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: flow animation -->
      <div class="relative">
        <div class="u-card overflow-hidden" style="max-height: 520px;">
          <p class="text-sm font-semibold text-white mb-5 text-center">Procesul automatizat</p>
          <div class="flow-scroll-mask flow-scroll-content space-y-4">
            {[
              {icon: 'ShoppingBag', title: 'Achiziție Finalizată', sub: 'Client mulțumit de serviciu', time: 'acum 2 min', accent: true},
              {icon: 'MessageCircle', title: 'SMS / Email Trimis', sub: '"Mulțumim! Lasă o recenzie → link direct"', time: 'automat', accent: false},
              {icon: 'MousePointer', title: 'Click pe Link', sub: 'Redirecționare directă spre Google', time: 'imediat', accent: false},
              {icon: 'Star', title: 'Recenzie Primită', sub: '"Servicii excelente! Recomand cu încredere!"', time: '★★★★★', accent: true},
              {icon: 'TrendingUp', title: 'Rating Actualizat', sub: 'Google Business Profile — live', time: '+0.1 avg', accent: true},
            ].map((step, i) => (
              <div>
                <div class="flex items-start gap-3 rounded-xl p-4 border" style={`background: hsl(var(--color-surface-2)); border-color: ${step.accent ? 'var(--brand-border)' : 'hsl(var(--color-border))'};`}>
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background: ${step.accent ? 'var(--brand-soft)' : 'hsl(var(--color-bg))'}; border: 1px solid ${step.accent ? 'var(--brand-border)' : 'hsl(var(--color-border))'};`}>
                    <LucideIcon name={step.icon} size={16} style={`color: ${step.accent ? 'var(--brand-color)' : 'hsl(var(--color-muted))'};`} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                      <p class="text-sm font-semibold text-white">{step.title}</p>
                      <span class="text-[0.65rem] font-mono flex-shrink-0 ml-2" style={`color: ${step.accent ? 'var(--brand-color)' : 'hsl(var(--color-muted))'};`}>{step.time}</span>
                    </div>
                    <p class="text-xs mt-0.5" style="color: hsl(var(--color-muted));">{step.sub}</p>
                  </div>
                </div>
                {i < 4 && (
                  <div class="flex justify-center my-1">
                    <div class="w-px h-5" style="background: linear-gradient(to bottom, var(--brand-border), transparent);"></div>
                  </div>
                )}
              </div>
            ))}

            <!-- Success card -->
            <div class="rounded-xl p-4 text-center" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
              <LucideIcon name="CheckCircle" size={22} style="color: var(--brand-color); margin: 0 auto 8px;" />
              <p class="text-sm font-semibold" style="color: var(--brand-color);">Proces Finalizat!</p>
              <p class="text-xs mt-1" style="color: hsl(var(--color-muted));">Rating actualizat pe Google Business</p>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-4 -right-4 flex items-center gap-2 rounded-xl border px-3 py-2" style="background: hsl(var(--color-surface)); border-color: hsl(var(--color-border)); box-shadow: 0 8px 24px rgba(0,0,0,0.4);">
          <LucideIcon name="Sparkles" size={13} style="color: var(--brand-color);" />
          <span class="text-xs font-mono font-semibold text-white">Automatizat 100%</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ============================================================
     BENEFICII
     ============================================================ -->
<section class="py-20 lg:py-32 fade-in-up" style="background: hsl(var(--color-surface));">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="u-section-tag mb-5 inline-flex">
        <LucideIcon name="Award" size={12} />
        Ce obții
      </span>
      <h2 class="mb-4">Tot ce ai nevoie pentru<br/>o reputație online solidă</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {icon: 'Star',        title: 'Mai multe recenzii',      desc: 'Sistem automat care solicită recenzii la momentul potrivit, când clientul e mulțumit.'},
        {icon: 'ShieldCheck', title: 'Protecție reputație',     desc: 'Clienții nemulțumiți sunt direcționați privat. Ratingul Google rămâne curat.'},
        {icon: 'TrendingUp',  title: 'Vizibilitate crescută',   desc: 'Mai multe recenzii = poziție mai bună în Google Maps și mai mulți clienți noi.'},
        {icon: 'BarChart2',   title: 'Rapoarte lunare',         desc: 'Urmărești evoluția ratingului și numărul de recenzii noi în fiecare lună.'},
        {icon: 'Zap',         title: 'Integrare simplă',        desc: 'Nu necesită schimbări în fluxul tău de lucru. Se configurează o singură dată.'},
        {icon: 'Heart',       title: 'Suport dedicat',          desc: 'Echipa noastră monitorizează sistemul și intervine rapid dacă apare ceva.'},
      ].map(b => (
        <div class="u-card u-card-hover flex flex-col gap-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--brand-soft); border: 1px solid var(--brand-border);">
            <LucideIcon name={b.icon} size={18} style="color: var(--brand-color);" />
          </div>
          <div>
            <h3 class="text-sm font-semibold text-white mb-2">{b.title}</h3>
            <p class="text-sm" style="color: hsl(var(--color-muted)); line-height: 1.6;">{b.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     FILTRARE INTELIGENTĂ
     ============================================================ -->
<section class="py-20 lg:py-32 fade-in-up">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: interactive feedback flow -->
      <div class="relative">
        <div class="u-card p-6" id="feedback-flow">
          <p class="text-xs font-mono text-center mb-5 uppercase tracking-widest" style="color: hsl(var(--color-muted));">Feedback Flow — interactiv</p>

          <!-- Rating card -->
          <div class="rounded-xl border p-5 mb-4" style="background: hsl(var(--color-surface-2)); border-color: hsl(var(--color-border));">
            <p class="text-sm font-semibold text-white text-center mb-4">Cum ne evaluezi experiența?</p>
            <div class="flex justify-center gap-2 mb-1" id="ff-stars">
              {[1,2,3,4,5].map(n => (
                <button
                  type="button"
                  data-star={n}
                  class="ff-star transition-transform hover:scale-110 focus:outline-none"
                  aria-label={`${n} stele`}
                  style="background: none; border: none; cursor: pointer; padding: 2px;"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="hsl(38 92% 55%)" stroke="hsl(38 92% 55%)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </button>
              ))}
            </div>
            <p class="text-center text-[0.65rem] font-mono mt-2" id="ff-hint" style="color: hsl(var(--color-muted));">Apasă pe o stea pentru a vedea ce se întâmplă</p>
          </div>

          <!-- Branch labels -->
          <div class="grid grid-cols-2 gap-3 mb-4">
            <div id="ff-low-label" class="rounded-xl p-3 text-center border transition-all duration-300" style="background: hsl(var(--color-bg)); border-color: hsl(var(--color-border)); opacity: 0.5;">
              <p class="text-xs font-semibold text-white mb-0.5">1–3 Stele</p>
              <p class="text-[0.65rem] font-mono" style="color: hsl(var(--color-muted));">Feedback privat</p>
            </div>
            <div id="ff-high-label" class="rounded-xl p-3 text-center border transition-all duration-300" style="background: var(--brand-soft); border-color: var(--brand-border); opacity: 0.5;">
              <p class="text-xs font-semibold text-white mb-0.5">4–5 Stele</p>
              <p class="text-[0.65rem] font-mono" style="color: var(--brand-color);">Google / Facebook</p>
            </div>
          </div>

          <!-- Result cards — stacked, no layout jump -->
          <div style="position: relative; height: 72px;">

            <div id="ff-result-private" class="rounded-xl border p-4 flex items-start gap-3" style="position: absolute; inset: 0; background: hsl(var(--color-surface-2)); border-color: hsl(0 80% 55% / 0.3); opacity: 0; transition: opacity 0.3s ease; pointer-events: none;">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: hsl(0 80% 55% / 0.1); border: 1px solid hsl(0 80% 55% / 0.2);">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="hsl(0 80% 60%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <div>
